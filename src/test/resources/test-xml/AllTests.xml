<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  AllTests.xml — Full Regression Suite

  TRAINING NOTES:
  ─────────────────────────────────────────────────────────────
  parallel="false"  — tests run one class at a time (sequential).
  Change to parallel="classes" to run each <test> block in its
  own thread. For parallel execution, BaseTest must use
  ThreadLocal<WebDriver> instead of a static field.

  verbose="1" — controls TestNG console output detail:
    0 = silent, 1 = summary only, 2 = method names, 10 = full detail

  Run with: mvn test  (default suite configured in pom.xml)
  Or:       mvn test -Dsuite=AllTests
-->
<suite name="All Tests Suite" parallel="false" verbose="1">

    <test name="Login Tests">
        <classes><class name="testcases.LoginTests"/></classes>
    </test>

    <test name="Dropdown Tests">
        <classes><class name="testcases.DropdownTests"/></classes>
    </test>

    <test name="Context Menu Tests">
        <classes><class name="testcases.ContextMenuTests"/></classes>
    </test>

    <test name="JavaScript Alerts Tests">
        <classes><class name="testcases.AlertsTests"/></classes>
    </test>

    <test name="File Upload Tests">
        <classes><class name="testcases.FileUploadTests"/></classes>
    </test>

    <test name="Modal Tests">
        <classes><class name="testcases.ModalTests"/></classes>
    </test>

</suite>
